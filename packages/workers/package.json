{
  "name": "mythos-workers",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "pnpm run run-all",
    "copy": "tsx src/copy.worker.ts",
    "image": "tsx src/image.worker.ts",
    "convert:video": "tsx src/convert.video.worker.ts",
    "publish": "tsx src/publish.worker.ts",
    "dev:publish": "tsx src/publish.ts",
    "scheduler": "pnpm run dev:scheduler",
    "dev:scheduler": "tsx src/scheduler.ts",
    "analytics": "tsx src/analytics.worker.ts",
    "consume": "tsx src/queue-consumer.ts",
    "run-all": "run-p dev:publish dev:scheduler analytics consume"
  },
  "dependencies": {
    "drizzle-orm": "0.33.0",
    "node-fetch": "3.3.2",
    "pg": "8.12.0",
    "tsx": "4.19.1",
    "@mythos/ai-engine": "workspace:*"
  },
  "devDependencies": {
    "npm-run-all": "4.1.5",
    "typescript": "5.6.2"
