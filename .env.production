# App
NEXTAUTH_URL=https://app.mythos.com
NEXTAUTH_SECRET=prod-super-secret-key-32chars-min
NEXT_PUBLIC_BASE_URL=https://app.mythos.com

# Database & queue
DATABASE_URL=postgres://mythos:mythos@db:5432/mythos
UPSTASH_REDIS_REST_URL=https://prod-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=prod-upstash-token

# OAuth providers
GOOGLE_CLIENT_ID=prod-google-client-id
GOOGLE_CLIENT_SECRET=prod-google-client-secret
GITHUB_CLIENT_ID=prod-github-client-id
GITHUB_CLIENT_SECRET=prod-github-client-secret

# AI providers (at least one required)
OPENAI_API_KEY=sk-prod-openai-placeholder
ANTHROPIC_API_KEY=anthropic-prod-placeholder

# Social platform credentials
META_APP_ID=prod-meta-app-id
META_APP_SECRET=prod-meta-app-secret
TWITTER_CLIENT_ID=prod-twitter-client-id
TWITTER_CLIENT_SECRET=prod-twitter-client-secret
LINKEDIN_CLIENT_ID=prod-linkedin-client-id
LINKEDIN_CLIENT_SECRET=prod-linkedin-client-secret

# Email
EMAIL_SERVER=smtp://user:pass@smtp.local:587
EMAIL_FROM="Mythos <no-reply@mythos.com>"

# Analytics & links
GA4_MEASUREMENT_ID=ga4-measurement-id-placeholder
GA4_API_SECRET=ga4-api-secret-placeholder
BITLY_TOKEN=bitly-token-placeholder
